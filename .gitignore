# -----------------------------
# STORX Fetus MCX GUI .gitignore
# -----------------------------

# Python cache / build artifacts
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/
.ipynb_checkpoints/

# Virtual environments
.venv/
venv/
env/
ENV/

# IDE / editor files
.vscode/
.idea/
*.swp
*.swo

# OS files
.DS_Store
Thumbs.db
desktop.ini

# Logs
*.log

# Keep original CT .mat volumes
# Recommended: track these with Git LFS if files are large.
!volumes/
!volumes/*.mat

# Ignore generated MCX/PMCX outputs
mcx_export/
batch_mcx_results/
outputs/
results/

# Generated transformed volumes and photon results
*.npy
*.npz
*.bin
*.jdat
*.mc2
*.nii
*.nii.gz

# But do not ignore source .mat files in volumes/
!volumes/*.mat

# Optional local notes/configs
local_config.json
source_locations.json
